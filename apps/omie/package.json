{
  "name": "@aurea/omie",
  "version": "1.0.0",
  "description": "Backend de integração entre CRM AUREA e ERP OMIE",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "omie",
    "crm",
    "integration",
    "webhook"
  ],
  "author": "Equipe AUREA",
  "license": "ISC",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@aurea/shared": "workspace:*",
    "@supabase/supabase-js": "^2.91.0",
    "axios": "^1.6.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "pino": "^10.2.1",
    "pino-http": "^11.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@aurea/eslint-config": "workspace:*",
    "@aurea/tsconfig": "workspace:*",
    "@eslint/js": "^9.39.4",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.7",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.17",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.17"
  }
}
